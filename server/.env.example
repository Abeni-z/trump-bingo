# ========== Render (API server) ==========
NODE_ENV=production
PORT=5000

# ========== Database (Supabase PostgreSQL) ==========
DB_HOST=aws-1-eu-central-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your_supabase_database_password
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:your_password@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_LOGGING=false

# ========== Auth ==========
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret

# ========== CORS — Vercel frontends (comma-separated, no trailing slash) ==========
# Replace with your real Vercel URLs or custom domains:
# CORS_ORIGINS=https://trump-bingo-client.vercel.app,https://trump-bingo-admin.vercel.app
# With custom domains:
CORS_ORIGINS=https://play.yourdomain.com,https://admin.yourdomain.com

# ========== Reference URLs (optional, for your notes) ==========
API_URL=https://trump-bingo-api.onrender.com
CLIENT_URL=https://trump-bingo-client.vercel.app
ADMIN_URL=https://trump-bingo-admin.vercel.app
