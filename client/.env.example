# TRUMP Bingo — Client (Vercel)
# Local: copy to .env
# Vercel: Project → Settings → Environment Variables → Production

# Local development
VITE_API_URL=http://localhost:5000/api

# Production — your Render API URL (must end with /api)
# VITE_API_URL=https://trump-bingo.onrender.com/api
# Or custom domain:
# VITE_API_URL=https://api.yourdomain.com/api
